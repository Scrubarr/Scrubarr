SCRUBARR_HOST=127.0.0.1
SCRUBARR_PORT=8098
SCRUBARR_DATA_DIR=./data
SCRUBARR_LOG_DIR=./logs
SCRUBARR_CONFIG_FILE=./data/config.json
SCRUBARR_TIMEZONE=Etc/UTC
# Optional JSON manifest: {"version":"1.0.0","releaseUrl":"https://...","notes":"..."}
SCRUBARR_UPDATE_MANIFEST_URL=

# Docker host folders mounted into /data and /logs.
# For a production install, point these at a stable app-data location.
SCRUBARR_DATA_HOST_PATH=./data
SCRUBARR_LOG_HOST_PATH=./logs

# Optional Docker queue mounts for Emby/Jellyfin Leaving Soon libraries.
# Keep Settings > media server > queue paths as the paths Emby/Jellyfin can see.
# Set these host paths to the matching folders Docker should write into.
# The .strm targets must be playable from the media server's point of view.
SCRUBARR_MOVIE_QUEUE_HOST_PATH=./data/leaving-soon/movies
SCRUBARR_SERIES_QUEUE_HOST_PATH=./data/leaving-soon/series
SCRUBARR_MOVIE_QUEUE_WRITE_PATH=/queue/movies
SCRUBARR_SERIES_QUEUE_WRITE_PATH=/queue/series
